<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NovoriqFlow" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/flow_background</item>
        <item name="android:navigationBarColor">@color/flow_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/flow_background</item>
    </style>

    <style name="Theme.NovoriqFlow.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/flow_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_flow_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/flow_background</item>
        <item name="postSplashScreenTheme">@style/Theme.NovoriqFlow</item>
    </style>
</resources>
