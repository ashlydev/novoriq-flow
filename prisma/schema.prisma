  relatedEntityId  String?
  visibleRoles     String[]                @default([])
  isRead           Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  workspace        Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  relatedBusiness  BusinessProfile?        @relation("RelatedNetworkBusiness", fields: [relatedBusinessId], references: [id], onDelete: SetNull)

  @@index([workspaceId, isRead, createdAt])
  @@index([workspaceId, type, createdAt])
}

model BusinessTrustMetric {
  id                  String          @id @default(cuid())
  businessProfileId   String          @unique
  acceptedOrderCount  Int             @default(0)
  completedOrderCount Int             @default(0)
  cancelledOrderCount Int             @default(0)
  averageResponseHours Decimal?       @db.Decimal(8, 2)
  relationshipAgeDays Int             @default(0)
  profileCompleteness Int             @default(0)
  lastActivityAt      DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  businessProfile     BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
}
