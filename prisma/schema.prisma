model User {
  id                     String                 @id @default(cuid())
  fullName               String
  email                  String                 @unique
  phone                  String?
  avatarUrl              String?
  passwordHash           String
  role                   UserRole               @default(owner)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  memberships            WorkspaceMember[]
  sentQuotes             Quote[]                @relation("QuoteCreatedBy")
  sentInvoices           Invoice[]              @relation("InvoiceCreatedBy")
  loggedPayments         Payment[]              @relation("PaymentCreatedBy")
  loggedExpenses         Expense[]              @relation("ExpenseCreatedBy")
  loggedPurchases        Purchase[]             @relation("PurchaseCreatedBy")
  loggedPurchasePayments PurchasePayment[]      @relation("PurchasePaymentCreatedBy")
  recurringTemplates     RecurringInvoiceTemplate[] @relation("RecurringTemplateCreatedBy")
  cashEntries            CashEntry[]            @relation("CashEntryCreatedBy")
  attachments            Attachment[]           @relation("AttachmentUploadedBy")
  vaultDocuments         VaultDocument[]        @relation("VaultDocumentUploadedBy")
  activities             Activity[]             @relation("ActivityActor")
  auditLogs              AuditLog[]             @relation("AuditActor")
  sentInvites            TeamInvite[]           @relation("TeamInviteSentBy")
  teamProfiles           TeamMemberProfile[]
  approvalsRequested     ApprovalRequest[]      @relation("ApprovalRequestedBy")
  approvalsDecided       ApprovalRequest[]      @relation("ApprovalApprovedBy")
  approvalHistoryEntries ApprovalHistoryEntry[] @relation("ApprovalHistoryActor")
  stockAdjustments       StockAdjustment[]      @relation("StockAdjustmentCreatedBy")
  projects               ProjectJob[]           @relation("ProjectCreatedBy")
  createdNetworkPurchaseOrders NetworkPurchaseOrder[]      @relation("NetworkPurchaseOrderCreatedBy")
  purchaseOrderHistoryEntries  NetworkPurchaseOrderHistoryEntry[] @relation("NetworkPurchaseOrderHistoryActorUser")
  createdNetworkRFQs           NetworkRFQ[]                @relation("NetworkRFQCreatedBy")
  createdPaymentRequests       PaymentRequest[]            @relation("PaymentRequestCreatedBy")
  reconciledFinanceRecords     ReconciliationRecord[]      @relation("FinanceReconciledBy")
  capturedFinanceSnapshots     FinanceReadinessSnapshot[]  @relation("FinanceReadinessCapturedBy")
  createdPartnerFinancePackages PartnerFinancePackage[]    @relation("PartnerFinancePackageCreatedBy")
  updatedPermissionProfiles    PermissionProfile[]         @relation("PermissionProfileUpdatedBy")
  managedDepartments           Department[]                @relation("DepartmentManagerUser")
  departmentMemberships        DepartmentMembership[]      @relation("DepartmentMembershipUser")
  requestedMakerCheckerReviews MakerCheckerReview[]        @relation("MakerCheckerRequestedBy")
  reviewedMakerCheckerReviews  MakerCheckerReview[]        @relation("MakerCheckerReviewedBy")
  makerCheckerHistoryEntries   MakerCheckerReviewHistoryEntry[] @relation("MakerCheckerHistoryActor")
  updatedControlPolicies       ControlPolicy[]             @relation("ControlPolicyUpdatedBy")
  updatedBranchControls        BranchControlSetting[]      @relation("BranchControlUpdatedBy")
  createdExportJobs            ExportJob[]                 @relation("ExportJobCreatedBy")
  assistantSessions            AssistantSession[]          @relation("AssistantSessionUser")
  createdAutomationRules       AutomationRule[]            @relation("AutomationRuleCreatedBy")
  reviewedAnomalies            AnomalyEvent[]              @relation("AnomalyReviewedBy")
  assignedActionTasks          ActionTask[]                @relation("ActionTaskAssignedUser")
  createdAssistantDrafts       AssistantDraft[]            @relation("AssistantDraftCreatedBy")
  updatedIntelligenceSettings  IntelligenceSetting[]       @relation("IntelligenceSettingUpdatedBy")
}

model Workspace {
  id                 String                  @id @default(cuid())
  name               String
  category           BusinessCategory
  currency           CurrencyCode            @default(USD)
  phone              String?
  email              String?
  address            String?
  logoUrl            String?
  taxNumber          String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  members            WorkspaceMember[]
  customers          Customer[]
  suppliers          Supplier[]
  items              Item[]
  quotes             Quote[]
  invoices           Invoice[]
  recurringInvoices  RecurringInvoiceTemplate[]
  payments           Payment[]
  receipts           Receipt[]
  expenses           Expense[]
  purchases          Purchase[]
  purchasePayments   PurchasePayment[]
  cashEntries        CashEntry[]
  attachments        Attachment[]
  notifications      AppNotification[]
  activities         Activity[]
  auditLogs          AuditLog[]
  settings           WorkspaceSetting?
  branches           Branch[]
  teamInvites        TeamInvite[]
  teamProfiles       TeamMemberProfile[]
  approvals          ApprovalRequest[]
  stockProfiles      StockProfile[]
  stockAdjustments   StockAdjustment[]
  projects           ProjectJob[]
  recordAssignments  RecordAssignment[]
  vaultDocuments     VaultDocument[]
  templateSetting    TemplateSetting?
  operationalAlerts  OperationalAlert[]
  networkProfile     BusinessProfile?
  networkPreference  NetworkPreference?
  businessBookmarks  BusinessBookmark[]
  supplierLinks      SupplierBusinessLink[]
  relationshipActivities RelationshipActivity[]
  networkNotifications NetworkNotification[]
  paymentRequests     PaymentRequest[]
  reconciliations     ReconciliationRecord[]
  financeTransactions FinanceTransaction[]
  financeReadinessSnapshots FinanceReadinessSnapshot[]
  invoiceFinancingCandidates InvoiceFinancingCandidate[]
  supplierCreditTerms SupplierCreditTerm[]
  financeNotifications FinanceNotification[]
  partnerFinancePackages PartnerFinancePackage[]
  permissionProfiles PermissionProfile[]
  departments        Department[]
  departmentMemberships DepartmentMembership[]
  makerCheckerReviews MakerCheckerReview[]
  controlPolicies    ControlPolicy[]
  branchControlSettings BranchControlSetting[]
  exportJobs         ExportJob[]
  enterpriseNotifications EnterpriseNotification[]
  assistantSessions  AssistantSession[]
  automationRules    AutomationRule[]
  automationRuns     AutomationRun[]
  anomalyEvents      AnomalyEvent[]
  recommendations    RecommendationRecord[]
  actionTasks        ActionTask[]
  assistantDrafts    AssistantDraft[]
  predictiveInsights PredictiveInsight[]
  intelligentSummaries IntelligentSummary[]
  intelligenceNotifications IntelligenceNotification[]
  intelligenceSetting IntelligenceSetting?
}

model WorkspaceMember {
  id          String             @id @default(cuid())
  workspaceId String
  userId      String
  role        UserRole           @default(owner)
  createdAt   DateTime           @default(now())
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile     TeamMemberProfile?
  departmentMemberships DepartmentMembership[]

  @@unique([workspaceId, userId])
  @@index([workspaceId, role])
}

model WorkspaceSetting {
  id                         String    @id @default(cuid())
  workspaceId                String    @unique
  invoicePrefix              String    @default("INV")
  quotePrefix                String    @default("Q")
  receiptPrefix              String    @default("RCPT")
  purchasePrefix             String    @default("PO")
  dueSoonDays                Int       @default(7)
  defaultInvoiceDueDays      Int       @default(14)
  defaultPurchaseDueDays     Int       @default(14)
  significantExpenseThreshold Int      @default(500)
  notificationsEnabled       Boolean   @default(true)
  paymentRemindersEnabled    Boolean   @default(true)
  brandAccent                String    @default("#c9a95a")
  termsSnippet               String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  workspace                  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Branch {
  id                 String             @id @default(cuid())
  workspaceId        String
  name               String
  code               String
  address            String?
  phone              String?
  managerName        String?
  isPrimary          Boolean            @default(false)
  status             BranchStatus       @default(active)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockProfiles      StockProfile[]     @relation("PreferredStockBranch")
  stockAdjustments   StockAdjustment[]
  approvals          ApprovalRequest[]
  projects           ProjectJob[]
  recordAssignments  RecordAssignment[]
  vaultDocuments     VaultDocument[]
  operationalAlerts  OperationalAlert[]
  networkPurchaseOrders NetworkPurchaseOrder[]
  networkRFQs           NetworkRFQ[]
  departments           Department[]
  makerCheckerReviews   MakerCheckerReview[]
  controlPolicies       ControlPolicy[]
  branchControlSetting  BranchControlSetting?
  enterpriseNotifications EnterpriseNotification[]

  @@unique([workspaceId, code])
  @@index([workspaceId, status])
}

model Customer {
  id                String                    @id @default(cuid())
  workspaceId       String
  name              String
  email             String?
  phone             String?
  address           String?
  notes             String?
  isArchived        Boolean                   @default(false)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  workspace         Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  quotes            Quote[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoiceTemplate[]
  projects          ProjectJob[]

  @@index([workspaceId, name])
}

model Supplier {
  id         String    @id @default(cuid())
  workspaceId String
  name       String
  email      String?
  phone      String?
  address    String?
  notes      String?
  isArchived Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  expenses   Expense[]
  purchases  Purchase[]
  networkLinks SupplierBusinessLink[]
  supplierCreditTerm SupplierCreditTerm?

  @@index([workspaceId, name])
}

model Item {
  id               String             @id @default(cuid())
  workspaceId      String
  name             String
  kind             ItemKind
  description      String?
  sellingPrice     Decimal            @db.Decimal(12, 2)
  cost             Decimal?           @db.Decimal(12, 2)
  sku              String?
  category         String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  quoteLines       QuoteLineItem[]
  invoiceLines     InvoiceLineItem[]
  recurringInvoiceLines RecurringInvoiceLineItem[]
  purchaseLines    PurchaseLineItem[]
  stockProfile     StockProfile?
  stockAdjustments StockAdjustment[]
  catalogItems     SupplierCatalogItem[]

  @@index([workspaceId, name])
  @@index([workspaceId, sku])
}

model Quote {
  id                String              @id @default(cuid())
  workspaceId       String
  customerId        String
  createdById       String
  reference         String
  issueDate         DateTime
  expiryDate        DateTime
  status            QuoteStatus         @default(draft)
  discountAmount    Decimal             @db.Decimal(12, 2)
  taxRate           Decimal             @db.Decimal(5, 2)
  notes             String?
  convertedInvoiceId String?             @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer          Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy         User                @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lineItems         QuoteLineItem[]
  convertedInvoice  Invoice?            @relation("ConvertedQuoteInvoice", fields: [convertedInvoiceId], references: [id])
  linkedInvoices    Invoice[]           @relation("LinkedQuoteInvoice")

  @@unique([workspaceId, reference])
  @@index([workspaceId, status])
}

model QuoteLineItem {
  id          String   @id @default(cuid())
  quoteId     String
  itemId      String?
  sortOrder   Int      @default(0)
  name        String
  description String?
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  unitCost    Decimal? @db.Decimal(12, 2)
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  item        Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
}

model Invoice {
  id                 String                  @id @default(cuid())
  workspaceId        String
  customerId         String
  createdById        String
  linkedQuoteId      String?
  recurringTemplateId String?
  reference          String
  issueDate          DateTime
  dueDate            DateTime
  status             InvoiceStatus           @default(draft)
  discountAmount     Decimal                 @db.Decimal(12, 2)
  taxRate            Decimal                 @db.Decimal(5, 2)
  notes              String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  workspace          Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer           Customer                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy          User                    @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  linkedQuote        Quote?                  @relation("LinkedQuoteInvoice", fields: [linkedQuoteId], references: [id], onDelete: SetNull)
  sourceQuote        Quote?                  @relation("ConvertedQuoteInvoice")
  recurringTemplate  RecurringInvoiceTemplate? @relation("RecurringTemplateInvoices", fields: [recurringTemplateId], references: [id], onDelete: SetNull)
  lineItems          InvoiceLineItem[]
  payments           Payment[]
  receipts           Receipt[]
  paymentRequests    PaymentRequest[]
  reconciliationRecords ReconciliationRecord[]
  financeTransactions FinanceTransaction[]     @relation("FinanceTransactionInvoice")
  financingCandidate InvoiceFinancingCandidate?

  @@unique([workspaceId, reference])
  @@index([workspaceId, status, dueDate])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  itemId      String?
  sortOrder   Int      @default(0)
  name        String
  description String?
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  unitCost    Decimal? @db.Decimal(12, 2)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item        Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
}

model RecurringInvoiceTemplate {
  id               String                @id @default(cuid())
  workspaceId      String
  customerId       String
  createdById      String
  label            String
  frequency        RecurringFrequency
  startDate        DateTime
  nextRunDate      DateTime
  dueInDays        Int
  isActive         Boolean               @default(true)
  discountAmount   Decimal               @db.Decimal(12, 2)
  taxRate          Decimal               @db.Decimal(5, 2)
  notes            String?
  lastGeneratedAt  DateTime?
  createdAt        DateTime              @default(now())
